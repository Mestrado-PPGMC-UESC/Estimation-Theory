function estimador = EstimadorLevenbergMarquardt(numero_passos, dados_observados, max_iter, tolerancia, epsilon, tau, parametros_iniciais)

    estimador = struct();

    estimador.numero_passos = numero_passos;

    // Extrai condições iniciais automaticamente
    estimador.I0 = dados_observados(1,1);
    estimador.S0 = dados_observados(1,2);
    estimador.R0 = dados_observados(1,3);

    // Dados observados
    estimador.dados_observados = dados_observados;

    // Configurações numéricas
    estimador.max_iter = max_iter;
    estimador.tolerancia = tolerancia;
    estimador.epsilon = epsilon;

    // Amortecimento inicial
    estimador.tau = tau;

    // Chute inicial dos parâmetros [beta; alpha; k]
    estimador.parametros_iniciais = parametros_iniciais;

endfunction

function [parametros, historico_beta, historico_alpha, historico_k, historico_erro, historico_mu, iteracoes] = estimar_levenberg_marquardt(estimador)

    parametros = estimador.parametros_iniciais;

    historico_beta = [];
    historico_alpha = [];
    historico_k = [];
    historico_erro = [];
    historico_mu = [];
    
    // Calcula Jacobiana inicial
    residuo = calcular_residuo_levenberg_marquardt(estimador, parametros);
    
    J = calcular_jacobiana_numerica_levenberg_marquardt(estimador, parametros, residuo);
    
    A0 = J' * J;
    
    // Mu inicial do LM
    mu = estimador.tau * max(diag(A0));
    
    for iteracao = 1:estimador.max_iter

        residuo = calcular_residuo_levenberg_marquardt(estimador, parametros);
        J = calcular_jacobiana_numerica_levenberg_marquardt(estimador, parametros, residuo);

        erro_atual = norm(residuo);

        historico_beta($+1) = parametros(1);
        historico_alpha($+1) = parametros(2);
        historico_k($+1) = parametros(3);
        historico_erro($+1) = erro_atual;
        historico_mu($+1) = mu;

        // Sistema LM: (J'J + mu I) delta = J'r
        A = J' * J + mu * eye(length(parametros), length(parametros));
        b = J' * residuo;

        delta = A \ b;

        parametros_teste = calcular_parametros_teste_levenberg_marquardt(estimador, parametros, delta);

        residuo_teste = calcular_residuo_levenberg_marquardt(estimador, parametros_teste);
        erro_teste = norm(residuo_teste);

        reducao_real = erro_atual - erro_teste;
        reducao_prevista = delta' * b;

        xi = calcular_xi_levenberg_marquardt(estimador, reducao_real, reducao_prevista);

        if mu == 0 then
            [parametros, parar] = atualizar_parametros_sem_xi_levenberg_marquardt(estimador, parametros, parametros_teste, delta);
        else
            [parametros, parar] = atualizar_parametros_com_protecao_levenberg_marquardt(estimador, parametros, parametros_teste, delta, xi);
        end

        mu = atualizar_mu_levenberg_marquardt(estimador, xi, mu);

        if parar then
            break;
        end

    end

    iteracoes = iteracao;

endfunction


function simulacao = simular_com_parametros_levenberg_marquardt(estimador, parametros)

    beta = parametros(1);
    alpha = parametros(2);
    k = parametros(3);

    modelo = ModeloPropagacaoInformacao(beta, alpha, k);
    simulador = Simulador(modelo, estimador.numero_passos);

    [I, S, R] = simulador.executar(simulador,estimador.I0, estimador.S0, estimador.R0);

    simulacao = [I, S, R];

endfunction


function residuo = calcular_residuo_levenberg_marquardt(estimador, parametros)

    simulacao = simular_com_parametros_levenberg_marquardt(estimador, parametros);

    residuo_matriz = estimador.dados_observados - simulacao;

    residuo = matrix(residuo_matriz, -1, 1);

endfunction


function J = calcular_jacobiana_numerica_levenberg_marquardt(estimador, parametros, residuo_base)

    n_residuos = length(residuo_base);
    n_parametros = length(parametros);

    J = zeros(n_residuos, n_parametros);

    for j = 1:n_parametros

        parametros_perturbados = parametros;
        parametros_perturbados(j) = parametros_perturbados(j) + estimador.epsilon;

        residuo_perturbado = calcular_residuo_levenberg_marquardt(estimador, parametros_perturbados);

        J(:,j) = (residuo_perturbado - residuo_base) / estimador.epsilon;

    end

endfunction

function xi = calcular_xi_levenberg_marquardt(estimador, reducao_real, reducao_prevista)

    if abs(reducao_prevista) < 1e-15 then
        xi = 0;
        return;
    end

    xi = reducao_real / reducao_prevista;

endfunction

function aceito = aceitar_passo_levenberg_marquardt(estimador, xi)

    aceito = xi > 0;

endfunction

function novo_mu = atualizar_mu_levenberg_marquardt(estimador, xi, mu)

    if mu == 0 then
        novo_mu = 0;
        return;
    end

    if xi < 0.25 then
        novo_mu = 2 * mu;

    elseif xi > 0.75 then
        novo_mu = mu / 3;

    else
        novo_mu = mu;
    end

endfunction


function parametros_teste = calcular_parametros_teste_levenberg_marquardt(estimador, parametros, delta)

    parametros_teste = parametros - delta;

    // Impede parâmetros negativos ou nulos
    parametros_teste = max(parametros_teste, 1e-8);

endfunction


function [parametros, parar] = atualizar_parametros_com_protecao_levenberg_marquardt(estimador, parametros, parametros_teste, delta, xi)

    parar = %f;

    if or(~isfinite(parametros_teste)) then
        parar = %t;
        return;
    end

    if aceitar_passo_levenberg_marquardt(estimador, xi) then
        parametros = parametros_teste;
    end

    if norm(delta) < estimador.tolerancia then
        parar = %t;
    end

endfunction


function [parametros, parar] = atualizar_parametros_sem_xi_levenberg_marquardt(estimador, parametros, parametros_teste, delta)

    parar = %f;

    if or(~isfinite(parametros_teste)) then
        parar = %t;
        return;
    end

    parametros = parametros_teste;

    if norm(delta) < estimador.tolerancia then
        parar = %t;
    end

endfunction
